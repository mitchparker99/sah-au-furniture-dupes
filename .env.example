# ── au-furniture-dupes — environment ─────────────────────────────────────────
# Copy this file to `.env` and fill in values. EVERYTHING here is optional for
# the core pipeline (match + build run with zero secrets). Keys only unlock
# extras (vision matching, photo search, affiliate tagging).

# Public site identity. SITE_URL is used for canonical/OG tags + sitemap.
SITE_NAME=Lookalike Living
SITE_URL=https://lookalikeliving.com.au

# ── Claude (optional — vision score blend + photo search) ────────────────────
# Without a key: matching falls back to pure spec-based scoring (still good).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
# Set VISION_ENABLED=true to blend a Claude image-pair similarity score into
# the spec score (0.65 spec / 0.35 vision). Costs per pair — capped below.
VISION_ENABLED=
VISION_MAX_PAIRS=25

# ── Affiliate tagging (optional) ─────────────────────────────────────────────
# Leave blank until networks approve you; links fall back to clean UTM-tagged
# outbound URLs. Commission Factory covers Temple & Webster & friends.
AFFILIATE_CF_ID=
AFFILIATE_IMPACT_ID=
UTM_SOURCE=lookalikeliving

# ── Ops ───────────────────────────────────────────────────────────────────────
# Days before a price is flagged stale in the nightly staleness report.
STALE_DAYS=45
